[
  {
    "name": "github",
    "host": "github.com",
    "url": "https://github.com/{username}",
    "detect": {
      "type": "status_code",
      "found": 200,
      "not_found": 404
    },
    "modes_allowed": [
      "prospect",
      "selfcheck",
      "pentest"
    ]
  },
  {
    "name": "github_api",
    "host": "api.github.com",
    "url": "https://api.github.com/users/{username}",
    "detect": {
      "type": "status_code",
      "found": 200,
      "not_found": 404
    },
    "headers": {
      "Accept": "application/vnd.github+json"
    },
    "modes_allowed": [
      "prospect",
      "selfcheck",
      "pentest"
    ]
  },
  {
    "name": "gitlab",
    "host": "gitlab.com",
    "url": "https://gitlab.com/api/v4/users?username={username}",
    "detect": {
      "type": "body_marker",
      "found_when": {
        "contains": "\"username\":\"{username}\""
      },
      "not_found_when": {
        "regex": "^\\[\\]$"
      }
    },
    "modes_allowed": [
      "prospect",
      "selfcheck",
      "pentest"
    ]
  },
