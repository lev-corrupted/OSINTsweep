[
  {
    "name": "twitter",
    "host": "api.twitter.com",
    "method": "GET",
    "url": "https://api.twitter.com/i/users/email_available.json?email={email}",
    "registered_when": {
      "contains": "\"taken\":true"
    },
    "not_registered_when": {
      "contains": "\"taken\":false"
    },
    "rate_limit_per_min": 4,
    "modes_allowed": [
      "prospect",
      "selfcheck",
      "pentest"
    ]
  },
  {
    "name": "microsoft",
    "host": "login.live.com",
    "method": "POST",
    "url": "https://login.live.com/GetCredentialType.srf",
    "headers": {
      "Content-Type": "application/json; charset=UTF-8"
    },
    "json_body": {
      "username": "{email}",
      "isOtherIdpSupported": true,
      "checkPhones": false,
      "isRemoteNGCSupported": true,
      "isCookieBannerShown": false,
      "isFidoSupported": true,
      "originalRequest": "",
      "country": "US",
      "forceotclogin": false,
      "isExternalFederationDisallowed": false,
      "isRemoteConnectSupported": false,
      "federationFlags": 3
    },
    "registered_when": {
      "regex": "\"IfExistsResult\":\\s*0"
    },
    "not_registered_when": {
      "regex": "\"IfExistsResult\":\\s*1|\"ErrorHR\":\\s*\"80046703\""
    },
    "rate_limit_per_min": 6,
    "modes_allowed": [
      "prospect",
      "selfcheck",
      "pentest"
    ]
  },
  {
    "name": "github_email",
