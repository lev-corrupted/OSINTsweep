    },
    "registered_when": {
      "regex": "\"total_count\":\\s*[1-9]"
    },
    "not_registered_when": {
      "regex": "\"total_count\":\\s*0"
    },
    "rate_limit_per_min": 10,
    "modes_allowed": [
      "prospect",
      "selfcheck",
      "pentest"
    ]
  },
