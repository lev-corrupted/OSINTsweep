# Optional API keys — all sources without a key still work, these unlock higher-quality lookups
HUNTER_API_KEY=
HIBP_API_KEY=
GITHUB_TOKEN=

# Behavior toggles
OSINT_CACHE_PATH=osint_cache.db
OSINT_CACHE_TTL_HOURS=24
OSINT_GLOBAL_TIMEOUT_S=10
OSINT_PER_HOST_CONCURRENCY=4
OSINT_USER_AGENT="osint-toolkit/0.1 (+https://github.com/levtheswag/osint-toolkit)"
